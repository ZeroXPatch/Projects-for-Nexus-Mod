    <AssemblyName>ModShortcutReferenceHub</AssemblyName>
    <RootNamespace>ModShortcutReferenceHub</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <ModFolderName>ModShortcutReferenceHub</ModFolderName>
